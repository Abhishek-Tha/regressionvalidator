{
  "name": "blockguard",
  "version": "0.1.0",
  "description": "EDS block regression validation — GitHub Action, MCP server, and CLI",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/cli",
    "packages/action",
    "packages/mcp"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint packages/*/src --ext .ts",
    "clean": "rimraf packages/*/dist packages/*/tsconfig.tsbuildinfo",
    "typecheck": "tsc --build tsconfig.base.json"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
